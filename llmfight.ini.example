[General]
# Required: choose the local model to run. Tested models receive built-in
# sampling/context/token defaults unless you uncomment the override lines below.
ollama_default_model = qwen3.6:35b
ollama_api_url = http://localhost:11434/api/chat
ollama_keep_alive = 10m
# ollama_num_ctx = 90000
# max_tokens_fighter = 768
# max_tokens_judge = 6144
# ollama_temperature = 0.4
max_retries = 1
invalid_output_retries = 2
fighter_creation_mode = configured
fighter_A = A
fighter_B = B

[SIMULATION]
runs = 1
seed = 42
max_turns = 6

[DEFAULTS]
environment = an open arena

[DEFAULT_FIGHTER]
class = Generic Fighter
loadout = their bare fists and wits

[A]
# Display labels are shown to users and prompts; mechanics still use stable id A.
name = Sir Galant
class = Veteran Knight
loadout = longsword and tower shield
# Optional custom anatomy profile JSON. Omit, leave empty, or set to humanoid
# to use the default humanoid body plan.
# anatomy_profile = humanoid

[B]
# Display labels are shown to users and prompts; mechanics still use stable id B.
name = Shade
class = Cunning Assassin
loadout = poison dagger and smoke bombs
# anatomy_profile = humanoid
